@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

<table class="table table-striped">
    <thead>
        <table>
            <th>@Html.DisplayNameFor(model => model.BookingId)</th>
            <th>@Html.DisplayNameFor(model => model.Venue)</th>
            <th>@Html.DisplayNameFor(model => model.Event)</th>
            <th>@Html.DisplayNameFor(model => model.BookingDate)</th>
            <th>@Html.DisplayNameFor(model => model.CustomerName)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>Actions</th>
            </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingId</td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.Event?.EventName</td>
                <td>@item.BookingDate.ToString("MMM dd, yyyy")</td>
                <td>@item.CustomerName</td>
                <td>
                    @if (item.Status == EventEase.Models.BookingStatus.Confirmed)
                    {
                        <span class="badge bg-success">Confirmed</span>
                    }
                    else if (item.Status == EventEase.Models.BookingStatus.Pending)
                    {
                        <span class="badge bg-warning">Pending</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Cancelled</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>