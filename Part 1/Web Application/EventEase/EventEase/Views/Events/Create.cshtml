@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-plus-circle me-2"></i>Create Event
        </h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <div class="form-group">
                                    <label asp-for="EventName" class="control-label fw-bold">
                                        <i class="fas fa-tag me-1"></i>Event Name
                                    </label>
                                    <input asp-for="EventName" class="form-control" />
                                    <span asp-validation-for="EventName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <div class="form-group">
                                    <label asp-for="Description" class="control-label fw-bold">
                                        <i class="fas fa-align-left me-1"></i>Description
                                    </label>
                                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Start Date with separate date and time -->
                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label class="control-label fw-bold">
                                        <i class="fas fa-calendar-alt me-1"></i>Start Date
                                    </label>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <input type="date"
                                                   id="StartDate_Date"
                                                   name="StartDate_Date"
                                                   class="form-control"
                                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                        </div>
                                        <div class="col-md-5">
                                            <input type="time"
                                                   id="StartDate_Time"
                                                   name="StartDate_Time"
                                                   class="form-control"
                                                   value="09:00" />
                                        </div>
                                    </div>
                                    <input type="hidden" asp-for="StartDate" />
                                    <span asp-validation-for="StartDate" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle me-1"></i>Select date and time (hours and minutes only)
                                    </small>
                                </div>
                            </div>

                            <!-- End Date with separate date and time -->
                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label class="control-label fw-bold">
                                        <i class="fas fa-calendar-alt me-1"></i>End Date
                                    </label>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <input type="date"
                                                   id="EndDate_Date"
                                                   name="EndDate_Date"
                                                   class="form-control"
                                                   value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                                        </div>
                                        <div class="col-md-5">
                                            <input type="time"
                                                   id="EndDate_Time"
                                                   name="EndDate_Time"
                                                   class="form-control"
                                                   value="17:00" />
                                        </div>
                                    </div>
                                    <input type="hidden" asp-for="EndDate" />
                                    <span asp-validation-for="EndDate" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle me-1"></i>Select date and time (hours and minutes only)
                                    </small>
                                </div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <div class="form-group">
                                    <label asp-for="ImageUrl" class="control-label fw-bold">
                                        <i class="fas fa-image me-1"></i>Image URL
                                    </label>
                                    <input asp-for="ImageUrl" class="form-control" placeholder="https://via.placeholder.com/300x200" />
                                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle me-1"></i>Enter a URL for the event image
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mt-3">
                            <button type="submit" class="btn btn-primary" onclick="combineDateTime()">
                                <i class="fas fa-save me-2"></i>Create
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="fas fa-lightbulb me-2"></i>Tips
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Event names should be descriptive
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            End date must be after start date
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Time is in 24-hour format (e.g., 14:30 for 2:30 PM)
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Use valid image URLs (jpg, png, etc.)
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Combine date and time fields into the hidden DateTime field
        function combineDateTime() {
            var startDateValue = document.getElementById('StartDate_Date').value;
            var startTimeValue = document.getElementById('StartDate_Time').value;
            var endDateValue = document.getElementById('EndDate_Date').value;
            var endTimeValue = document.getElementById('EndDate_Time').value;

            if (startDateValue && startTimeValue) {
                var startDateTime = startDateValue + 'T' + startTimeValue + ':00';
                document.getElementById('StartDate').value = startDateTime;
            }

            if (endDateValue && endTimeValue) {
                var endDateTime = endDateValue + 'T' + endTimeValue + ':00';
                document.getElementById('EndDate').value = endDateTime;
            }
        }

        // Add event listeners to combine before form submission
        document.querySelector('form').addEventListener('submit', function(e) {
            combineDateTime();
        });

        // Add validation to ensure end date is after start date
        function validateDates() {
            var startDate = document.getElementById('StartDate_Date').value;
            var startTime = document.getElementById('StartDate_Time').value;
            var endDate = document.getElementById('EndDate_Date').value;
            var endTime = document.getElementById('EndDate_Time').value;

            if (startDate && startTime && endDate && endTime) {
                var start = new Date(startDate + 'T' + startTime);
                var end = new Date(endDate + 'T' + endTime);

                if (end <= start) {
                    alert('End date and time must be after start date and time.');
                    return false;
                }
            }
            return true;
        }

        document.querySelector('form').addEventListener('submit', function(e) {
            if (!validateDates()) {
                e.preventDefault();
            }
        });
    </script>
}