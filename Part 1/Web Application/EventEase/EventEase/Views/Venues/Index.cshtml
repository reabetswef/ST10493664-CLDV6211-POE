@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-building me-2"></i>Venues
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Venue
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-building"></i>
            <h3>No Venues Found</h3>
            <p>Get started by adding your first venue</p>
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="fas fa-plus me-2"></i>Add Venue
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.VenueName" onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'">
                        <div class="card-body">
                            <h5 class="card-title">@item.VenueName</h5>
                            <p class="card-text">
                                <i class="fas fa-map-marker-alt me-2 text-muted"></i>@item.Location<br />
                                <i class="fas fa-users me-2 text-muted"></i>Capacity: @item.Capacity people
                            </p>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-sm btn-info">
                                    <i class="fas fa-info-circle"></i> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>