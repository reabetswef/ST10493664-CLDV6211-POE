@model EventEase.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-trash-alt me-2"></i>Delete Event
        </h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>Warning!</strong> Are you sure you want to delete this event? This action cannot be undone.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row">
                <div class="col-md-5">
                    <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.EventName"
                         onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'">
                </div>
                <div class="col-md-7">
                    <dl class="row">
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.EventName)
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.EventName)
                        </dd>

                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.Description)
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Description)
                        </dd>

                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.StartDate)
                        </dt>
                        <dd class="col-sm-9">
                            @Model.StartDate.ToString("MMMM dd, yyyy hh:mm tt")
                        </dd>

                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.EndDate)
                        </dt>
                        <dd class="col-sm-9">
                            @Model.EndDate.ToString("MMMM dd, yyyy hh:mm tt")
                        </dd>

                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.ImageUrl)
                        </dt>
                        <dd class="col-sm-9">
                            <a href="@Model.ImageUrl" target="_blank">View Image</a>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <form asp-action="Delete">
                <input type="hidden" asp-for="EventId" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt me-2"></i>Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </form>
        </div>
    </div>
</div>