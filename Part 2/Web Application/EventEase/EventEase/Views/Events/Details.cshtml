@model EventEase.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-calendar-alt me-2"></i>Event Details
        </h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.EventId" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row">
                <div class="col-md-5 text-center">
                    <img src="@Model?.ImageUrl" class="detail-image" alt="@Model?.EventName"
                         onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'">
                    @if (!string.IsNullOrEmpty(Model?.ImageUrl) && !Model.ImageUrl.Contains("via.placeholder.com"))
                    {
                        <div class="mt-2">
                            <a href="@Model.ImageUrl" target="_blank" class="btn btn-sm btn-info">
                                <i class="fas fa-external-link-alt me-1"></i>View Full Size
                            </a>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <dl class="row">
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.EventName)
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.EventName)
                        </dd>
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.Description)
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Description)
                        </dd>
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.StartDate)
                        </dt>
                        <dd class="col-sm-9">
                            @Model?.StartDate.ToString("MMMM dd, yyyy hh:mm tt")
                        </dd>
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.EndDate)
                        </dt>
                        <dd class="col-sm-9">
                            @Model?.EndDate.ToString("MMMM dd, yyyy hh:mm tt")
                        </dd>
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.ImageUrl)
                        </dt>
                        <dd class="col-sm-9">
                            <input type="text" class="form-control form-control-sm" readonly value="@Model?.ImageUrl" />
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>