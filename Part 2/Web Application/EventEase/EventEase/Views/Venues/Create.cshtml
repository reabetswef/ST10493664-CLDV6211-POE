@model EventEase.ViewModels.VenueViewModel

@{
    ViewData["Title"] = "Create Venue";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-plus-circle me-2"></i>Create Venue
        </h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="VenueName" class="control-label fw-bold">
                                    <i class="fas fa-tag me-1"></i>Venue Name
                                </label>
                                <input asp-for="VenueName" class="form-control" />
                                <span asp-validation-for="VenueName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="Location" class="control-label fw-bold">
                                    <i class="fas fa-map-marker-alt me-1"></i>Location
                                </label>
                                <input asp-for="Location" class="form-control" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="Capacity" class="control-label fw-bold">
                                    <i class="fas fa-users me-1"></i>Capacity
                                </label>
                                <input asp-for="Capacity" class="form-control" type="number" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-group">
                                <label asp-for="ImageFile" class="control-label fw-bold">
                                    <i class="fas fa-image me-1"></i>Venue Image
                                </label>
                                <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                                <span asp-validation-for="ImageFile" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle me-1"></i>Upload a JPG, PNG, or GIF image
                                </small>
                            </div>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Create
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="fas fa-lightbulb me-2"></i>Image Tips
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Supported formats: JPG, PNG, GIF
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Maximum file size: 5MB
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Images are stored locally using Azurite
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}